<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SK_01 API Test Suite" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>

    <test name="API Playground Tests">
        <classes>
            <class name="API_Playgraund.admin_flow"/>
            <class name="API_Playgraund.user_flow"/>
            <class name="API_Playgraund.anon_flow"/>
        </classes>
    </test>

    <test name="Automation Exercise Tests">
        <classes>
            <class name="Automation_Exercise.automationexerciseTest"/>
            <class name="Automation_Exercise.get_product_list"/>
            <class name="Automation_Exercise.post_search"/>
        </classes>
    </test>

</suite>
